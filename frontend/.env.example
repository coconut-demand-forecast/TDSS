VITE_API_URL=http://localhost:8000

# Optional — enables Google Maps route lookup (distance/duration) in the
# Routes page. If unset, the app falls back to Manual mode automatically.
# Restrict this key by HTTP referrer in Google Cloud Console, enable only
# Maps JavaScript API + Places API (New) + Routes API, and set a budget
# alert (see README.md for details).
VITE_GOOGLE_MAPS_API_KEY=
# Optional — a Map ID from Google Cloud Console for custom map styling.
# Leave unset to use Google's public DEMO_MAP_ID (no setup required).
VITE_GOOGLE_MAPS_MAP_ID=
